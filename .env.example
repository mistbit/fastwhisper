# Database
DATABASE_URL=sqlite+aiosqlite:///./storage/fastwhisper.db

# PostgreSQL（如需切回 Docker/PostgreSQL，可改为 postgresql+asyncpg://...）
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password
POSTGRES_DB=fastwhisper

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Auth - 固定 Token 认证
API_TOKEN=your_secure_token_here

# ASR Engine: whisper | sensevoice
ASR_ENGINE=whisper

# Whisper
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16
WHISPER_BEAM_SIZE=5
WHISPER_TEMPERATURE=0

# SenseVoice (FunASR) - higher accuracy for Chinese
SENSEVOICE_MODEL=iic/SenseVoiceSmall

# Diarization - pyannote 需要 HuggingFace Token
HUGGINGFACE_TOKEN=your_huggingface_token

# LLM Configuration
LLM_PROVIDER=qwen
LLM_API_KEY=your_llm_api_key
LLM_MODEL=qwen-max
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Storage
UPLOAD_DIR=./storage/uploads
RESULT_DIR=./storage/results
MAX_FILE_SIZE=524288000

# Local runtime mode
TASK_RUNNER=inline
ENABLE_SPEAKER_DIARIZATION=true
ENABLE_LLM_MINUTES=false

# Worker
MAX_CONCURRENT_TASKS=3
WORKER_LEASE_SECONDS=300
WORKER_HEARTBEAT_SECONDS=30
